<%- include('partials/header') %>

<div class="max-w-md mx-auto py-12">
    <div class="glass p-8 rounded-3xl border-cyan-500/20 shadow-2xl relative overflow-hidden">
        <!-- Glow accent -->
        <div class="absolute -top-12 -right-12 w-24 h-24 bg-cyan-500/20 blur-3xl rounded-full"></div>
        
        <h2 class="font-cyber text-2xl text-white mb-2">Initialize Profile</h2>
        <p class="text-slate-500 text-sm mb-8">Join the decentralized campus network.</p>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 p-4 rounded-lg bg-red-500/10 border border-red-500/30 text-red-400 text-sm">
                <%= error %>
            </div>
        <% } %>

        <form action="/register" method="POST" class="space-y-6">
            <div>
                <label class="block text-xs font-cyber text-slate-500 uppercase tracking-widest mb-2">Display Name</label>
                <input type="text" name="name" required placeholder="Major Tom" class="w-full bg-slate-900/50 border border-slate-800 rounded-xl px-4 py-3 text-white placeholder-slate-600 focus:outline-none focus:border-cyan-500 transition-colors">
            </div>

            <div>
                <div class="flex justify-between items-center mb-2">
                    <label class="block text-xs font-cyber text-slate-500 uppercase tracking-widest">Campus Email</label>
                    <span class="px-2 py-0.5 rounded bg-amber-500/10 text-amber-500 text-[8px] font-cyber uppercase tracking-wider border border-amber-500/20">
                        Verification Coming Soon
                    </span>
                </div>
                <input type="email" name="email" required placeholder="user@campus.edu" class="w-full bg-slate-900/50 border border-slate-800 rounded-xl px-4 py-3 text-white placeholder-slate-600 focus:outline-none focus:border-cyan-500 transition-colors">
            </div>

            <div>
                <label class="block text-xs font-cyber text-slate-500 uppercase tracking-widest mb-2">Password</label>
                <input type="password" name="password" required placeholder="••••••••" class="w-full bg-slate-900/50 border border-slate-800 rounded-xl px-4 py-3 text-white placeholder-slate-600 focus:outline-none focus:border-cyan-500 transition-colors">
            </div>

            <div>
                <label class="block text-xs font-cyber text-slate-500 uppercase tracking-widest mb-2">Assigned Dorm</label>
                <select name="dorm" class="w-full bg-slate-900/50 border border-slate-800 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-cyan-500 transition-colors">
                    <option value="North Hall">North Hall</option>
                    <option value="South Hall">South Hall</option>
                    <option value="East Tower">East Tower</option>
                    <option value="West Wing">West Wing</option>
                </select>
            </div>

            <button type="submit" class="w-full py-4 rounded-xl bg-cyan-500 text-slate-950 font-bold font-cyber hover:bg-cyan-400 transition-all shadow-lg shadow-cyan-500/20 uppercase tracking-tighter">
                Register Identity
            </button>
        </form>

        <p class="text-center text-slate-500 text-sm mt-8">
            Already have an account? 
            <a href="/login" class="text-cyan-400 hover:text-cyan-300 transition-colors font-medium">Access Hub</a>
        </p>
    </div>
</div>

<%- include('partials/footer') %>

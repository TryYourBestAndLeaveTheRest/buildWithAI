<%- include('partials/header') %>

<div class="max-w-4xl mx-auto py-12">
    <div class="flex items-center justify-between mb-12">
        <h1 class="font-cyber text-3xl font-bold text-white tracking-tight">User Dashboard</h1>
        <div class="px-4 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/30 text-cyan-400 text-xs font-cyber uppercase tracking-widest">
            Level 1 Access
        </div>
    </div>

    <% if (user) { %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            <div class="glass p-6 rounded-2xl border border-white/5">
                <p class="text-slate-500 text-[10px] font-cyber uppercase mb-1">Identity</p>
                <p class="text-xl text-white font-bold"><%= user.name %></p>
            </div>
            <div class="glass p-6 rounded-2xl border border-white/5">
                <p class="text-slate-500 text-[10px] font-cyber uppercase mb-1">Email</p>
                <p class="text-xl text-white font-bold"><%= user.email %></p>
            </div>
            <div class="glass p-6 rounded-2xl border border-white/5">
                <p class="text-slate-500 text-[10px] font-cyber uppercase mb-1">Station</p>
                <p class="text-xl text-white font-bold"><%= user.dorm %></p>
            </div>
        </div>

        <div class="glass p-8 rounded-3xl border-dashed border-slate-800 text-center">
            <p class="text-slate-500 font-cyber">No active transmissions from this unit.</p>
            <a href="/" class="mt-4 inline-block text-cyan-400 hover:text-white transition-colors text-sm font-cyber uppercase tracking-tighter underline">Start a Transmission</a>
        </div>
    <% } else { %>
        <div class="text-center py-20 glass rounded-3xl">
            <p class="text-slate-400 mb-6">No identity found in local storage.</p>
            <a href="/register" class="px-8 py-3 rounded-xl bg-cyan-500 text-slate-950 font-bold font-cyber hover:bg-cyan-400 transition-all">
                Initialize Hub Connection
            </a>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>

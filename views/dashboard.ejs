<%- include('partials/header') %>

<div class="max-w-5xl mx-auto py-10">

  <!-- Page header -->
  <div class="flex items-center justify-between mb-10">
    <div>
      <h1 class="font-cyber text-3xl font-bold text-white tracking-tight">Dashboard</h1>
      <p class="text-slate-500 text-sm mt-1">Your campus network hub</p>
    </div>
    <div class="px-4 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/30 text-cyan-400 text-xs font-cyber uppercase tracking-widest">
      <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse inline-block mr-2"></span>
      Online
    </div>
  </div>

  <% if (typeof flash !== 'undefined' && flash) { %>
    <div class="mb-6 p-4 rounded-xl bg-amber-500/10 border border-amber-500/30 text-amber-300 text-sm font-cyber uppercase tracking-widest">
      <%= flash === 'canceled' ? '✖ Transaction canceled — listing is back to active.' : flash %>
    </div>
  <% } %>

  <% if (user) { %>

    <!-- User stats strip -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
      <div class="glass p-5 rounded-2xl border border-white/5 text-center">
        <p class="text-3xl font-bold text-white mb-1"><%= myListings.length %></p>
        <p class="text-slate-500 text-[10px] font-cyber uppercase tracking-widest">My Listings</p>
      </div>
      <div class="glass p-5 rounded-2xl border border-white/5 text-center">
        <p class="text-3xl font-bold text-cyan-400 mb-1"><%= offersReceived.filter(t => t.status === 'pending').length %></p>
        <p class="text-slate-500 text-[10px] font-cyber uppercase tracking-widest">Offers In</p>
      </div>
      <div class="glass p-5 rounded-2xl border border-white/5 text-center">
        <p class="text-3xl font-bold text-amber-400 mb-1"><%= offersSent.filter(t => t.status === 'pending').length %></p>
        <p class="text-slate-500 text-[10px] font-cyber uppercase tracking-widest">Offers Out</p>
      </div>
      <div class="glass p-5 rounded-2xl border border-white/5 text-center">
        <p class="text-3xl font-bold text-green-400 mb-1"><%= [...offersReceived, ...offersSent].filter(t => t.status === 'completed').length %></p>
        <p class="text-slate-500 text-[10px] font-cyber uppercase tracking-widest">Completed</p>
      </div>
    </div>

    <!-- Profile strip -->
    <div class="glass p-6 rounded-2xl border border-white/5 mb-8 flex flex-wrap gap-6">
      <div>
        <p class="text-slate-500 text-[10px] font-cyber uppercase mb-1">Identity</p>
        <p class="text-white font-bold"><%= user.name %></p>
      </div>
      <div>
        <p class="text-slate-500 text-[10px] font-cyber uppercase mb-1">Email</p>
        <p class="text-white font-bold"><%= user.email %></p>
      </div>
      <% if (user.dorm) { %>
        <div>
          <p class="text-slate-500 text-[10px] font-cyber uppercase mb-1">Station</p>
          <p class="text-white font-bold"><%= user.dorm %></p>
        </div>
      <% } %>
      <div>
        <p class="text-slate-500 text-[10px] font-cyber uppercase mb-1">Member Since</p>
        <p class="text-white font-bold"><%= new Date(user.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
      </div>
    </div>

    <!-- Offers Received (I need to respond) -->
    <% const pendingIn = offersReceived.filter(t => t.status === 'pending'); %>
    <% if (pendingIn.length > 0) { %>
      <section class="mb-10">
        <h2 class="font-cyber text-lg text-white mb-4 flex items-center gap-3">
          <span class="w-1.5 h-6 bg-amber-500 rounded-full"></span>
          Offers Received
          <span class="px-2 py-0.5 rounded-full bg-amber-500/20 text-amber-400 text-xs"><%= pendingIn.length %></span>
        </h2>
        <div class="space-y-3">
          <% pendingIn.forEach(tx => { %>
            <a href="/transactions/<%= tx._id %>"
              class="glass flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-5 rounded-2xl border border-amber-500/20 hover:border-amber-500/40 transition-all group">
              <div>
                <p class="text-white font-semibold group-hover:text-amber-400 transition-colors"><%= tx.listing.title %></p>
                <p class="text-slate-500 text-xs mt-0.5"><%= tx.buyer.name %> from <%= tx.buyer.dorm || '—' %> wants this</p>
              </div>
              <span class="px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-400 text-[10px] font-cyber uppercase tracking-widest whitespace-nowrap">
                Awaiting your response →
              </span>
            </a>
          <% }); %>
        </div>
      </section>
    <% } %>

    <!-- Offers Sent (waiting on seller) -->
    <% const pendingOut = offersSent.filter(t => t.status === 'pending'); %>
    <% if (pendingOut.length > 0) { %>
      <section class="mb-10">
        <h2 class="font-cyber text-lg text-white mb-4 flex items-center gap-3">
          <span class="w-1.5 h-6 bg-cyan-500 rounded-full"></span>
          Offers Sent
          <span class="px-2 py-0.5 rounded-full bg-cyan-500/20 text-cyan-400 text-xs"><%= pendingOut.length %></span>
        </h2>
        <div class="space-y-3">
          <% pendingOut.forEach(tx => { %>
            <a href="/transactions/<%= tx._id %>"
              class="glass flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-5 rounded-2xl border border-cyan-500/20 hover:border-cyan-500/40 transition-all group">
              <div>
                <p class="text-white font-semibold group-hover:text-cyan-400 transition-colors"><%= tx.listing.title %></p>
                <p class="text-slate-500 text-xs mt-0.5">Seller: <%= tx.seller.name %> from <%= tx.seller.dorm || '—' %></p>
              </div>
              <span class="px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/30 text-cyan-400 text-[10px] font-cyber uppercase tracking-widest whitespace-nowrap">
                Waiting on seller →
              </span>
            </a>
          <% }); %>
        </div>
      </section>
    <% } %>

    <!-- My Listings -->
    <section class="mb-10">
      <h2 class="font-cyber text-lg text-white mb-4 flex items-center gap-3">
        <span class="w-1.5 h-6 bg-slate-500 rounded-full"></span>
        My Listings
        <span class="px-2 py-0.5 rounded-full bg-slate-800 text-slate-400 text-xs"><%= myListings.length %></span>
      </h2>
      <% if (myListings.length === 0) { %>
        <div class="glass p-8 rounded-3xl border-dashed border-slate-800 text-center">
          <p class="text-slate-500 font-cyber text-xs uppercase tracking-widest mb-4">No active transmissions from this unit.</p>
          <a href="/" class="inline-block text-cyan-400 hover:text-white transition-colors text-sm font-cyber uppercase tracking-tighter underline">
            Post a Listing
          </a>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <% myListings.forEach(item => { %>
            <div class="glass p-5 rounded-2xl border border-white/5 flex flex-col gap-2">
              <div class="flex justify-between items-start">
                <span class="text-[10px] font-cyber uppercase tracking-widest px-2 py-1 rounded
                  <%= item.status === 'active' ? 'bg-cyan-500/10 text-cyan-400' :
                      item.status === 'bargaining' ? 'bg-amber-500/10 text-amber-400' :
                      item.status === 'completed' ? 'bg-green-500/10 text-green-400' :
                                                    'bg-slate-700 text-slate-400' %>">
                  <%= item.status %>
                </span>
                <span class="text-xs text-slate-500"><%= item.price %></span>
              </div>
              <p class="text-white font-semibold text-sm"><%= item.title %></p>
              <p class="text-slate-500 text-xs line-clamp-2"><%= item.description %></p>
              <p class="text-[10px] font-cyber text-slate-600 uppercase"><%= item.type === 'have' ? '📦 Have' : '🔍 Need' %> &middot; <%= item.dorm %></p>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- Transaction History -->
    <%
      const allHistory = [...offersReceived, ...offersSent]
        .filter(t => ['completed','canceled'].includes(t.status))
        .sort((a, b) => new Date(b.updatedAt) - new Date(a.updatedAt));
    %>
    <% if (allHistory.length > 0) { %>
      <section>
        <h2 class="font-cyber text-lg text-white mb-4 flex items-center gap-3">
          <span class="w-1.5 h-6 bg-green-500 rounded-full"></span>
          History
          <span class="px-2 py-0.5 rounded-full bg-slate-800 text-slate-400 text-xs"><%= allHistory.length %></span>
        </h2>
        <div class="space-y-3">
          <% allHistory.forEach(tx => { %>
            <a href="/transactions/<%= tx._id %>"
              class="glass flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-5 rounded-2xl border border-white/5 hover:border-white/10 transition-all">
              <div>
                <p class="text-slate-300 font-semibold text-sm"><%= tx.listing.title %></p>
                <p class="text-slate-600 text-xs mt-0.5">
                  <%= new Date(tx.updatedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </p>
              </div>
              <span class="px-3 py-1 rounded-full text-[10px] font-cyber uppercase tracking-widest whitespace-nowrap
                <%= tx.status === 'completed' ? 'bg-green-500/10 border border-green-500/30 text-green-400' : 'bg-slate-700 border border-slate-600 text-slate-400' %>">
                <%= tx.status %>
              </span>
            </a>
          <% }); %>
        </div>
      </section>
    <% } %>

  <% } else { %>
    <div class="text-center py-20 glass rounded-3xl">
      <p class="text-slate-400 mb-6">No identity found. Please log in again.</p>
      <a href="/login" class="px-8 py-3 rounded-xl bg-cyan-500 text-slate-950 font-bold font-cyber hover:bg-cyan-400 transition-all">
        Login
      </a>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>

<%- include('partials/header') %>

<div class="max-w-6xl mx-auto py-8 lg:py-12 px-4">

  <!-- Page header -->
  <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12">
    <div>
      <div class="flex items-center gap-3 mb-2">
        <div class="w-1.5 h-8 bg-cyan-500 rounded-full"></div>
        <h1 class="font-cyber text-3xl font-bold text-white tracking-tight uppercase">Dashboard</h1>
      </div>
      <p class="text-slate-500 text-sm ml-4.5">Central Processing Unit &middot; <%= user.name %></p>
    </div>
    <div class="px-5 py-2 rounded-2xl bg-cyan-500/5 border border-cyan-500/20 text-cyan-400 text-[10px] font-cyber uppercase tracking-[0.2em] flex items-center self-start sm:self-auto">
      <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse inline-block mr-3"></span>
      System Active
    </div>
  </div>

  <% if (typeof flash !== 'undefined' && flash) { %>
    <div class="mb-8 p-5 rounded-2xl bg-amber-500/10 border border-amber-500/20 text-amber-300 text-xs font-cyber uppercase tracking-widest flex items-center gap-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
        <%= flash === 'canceled' ? 'Transaction canceled — listing is back to active.' : flash %>
    </div>
  <% } %>

  <% if (user) { %>

    <!-- User stats strip -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 mb-12">
      <div class="glass p-6 rounded-3xl border-white/5 relative overflow-hidden group transition-all hover:border-white/10">
        <div class="absolute -bottom-4 -right-4 text-white/5 font-cyber text-6xl select-none group-hover:text-white/10 transition-colors">01</div>
        <p class="text-4xl font-bold text-white mb-2 relative z-10"><%= myListings.length %></p>
        <p class="text-slate-500 text-[9px] font-cyber uppercase tracking-[0.2em] relative z-10">Total Transmissions</p>
      </div>
      <div class="glass p-6 rounded-3xl border-white/5 relative overflow-hidden group transition-all hover:border-white/10">
        <div class="absolute -bottom-4 -right-4 text-cyan-500/5 font-cyber text-6xl select-none group-hover:text-cyan-500/10 transition-colors">02</div>
        <p class="text-4xl font-bold text-cyan-400 mb-2 relative z-10"><%= offersReceived.filter(t => t.status === 'pending').length %></p>
        <p class="text-slate-500 text-[9px] font-cyber uppercase tracking-[0.2em] relative z-10">Incoming Offers</p>
      </div>
      <div class="glass p-6 rounded-3xl border-white/5 relative overflow-hidden group transition-all hover:border-white/10">
        <div class="absolute -bottom-4 -right-4 text-amber-500/5 font-cyber text-6xl select-none group-hover:text-amber-500/10 transition-colors">03</div>
        <p class="text-4xl font-bold text-amber-400 mb-2 relative z-10"><%= offersSent.filter(t => t.status === 'pending').length %></p>
        <p class="text-slate-500 text-[9px] font-cyber uppercase tracking-[0.2em] relative z-10">Outgoing Signals</p>
      </div>
      <div class="glass p-6 rounded-3xl border-white/5 relative overflow-hidden group transition-all hover:border-white/10">
        <div class="absolute -bottom-4 -right-4 text-green-500/5 font-cyber text-6xl select-none group-hover:text-green-500/10 transition-colors">04</div>
        <p class="text-4xl font-bold text-green-400 mb-2 relative z-10"><%= [...offersReceived, ...offersSent].filter(t => t.status === 'completed').length %></p>
        <p class="text-slate-500 text-[9px] font-cyber uppercase tracking-[0.2em] relative z-10">Successful Swaps</p>
      </div>
    </div>

    <!-- Profile strip -->
    <div class="glass p-8 rounded-3xl border-white/5 mb-10 flex flex-wrap items-center gap-x-12 gap-y-6 relative overflow-hidden group">
      <div class="absolute top-0 left-0 w-full h-0.5 bg-gradient-to-r from-transparent via-cyan-500/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
      <div class="min-w-[120px]">
        <p class="text-slate-500 text-[9px] font-cyber uppercase tracking-widest mb-2">Network ID</p>
        <p class="text-white font-bold text-sm"><%= user.name %></p>
      </div>
      <div class="min-w-[180px]">
        <p class="text-slate-500 text-[9px] font-cyber uppercase tracking-widest mb-2">Comms Channel</p>
        <p class="text-white font-bold text-sm"><%= user.email %></p>
      </div>
      <% if (user.dorm) { %>
        <div class="min-w-[120px]">
          <p class="text-slate-500 text-[9px] font-cyber uppercase tracking-widest mb-2">Station</p>
          <p class="text-white font-bold text-sm flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-cyan-500 rounded-full"></span>
            <%= user.dorm %>
          </p>
        </div>
      <% } %>
      <div class="ml-auto">
        <p class="text-slate-500 text-[9px] font-cyber uppercase tracking-widest mb-2">Active Since</p>
        <p class="text-slate-300 font-bold text-sm"><%= new Date(user.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
      </div>
    </div>

    <!-- Offers Received (I need to respond) -->
    <% const pendingIn = offersReceived.filter(t => t.status === 'pending'); %>
    <% if (pendingIn.length > 0) { %>
      <section class="mb-10">
        <h2 class="font-cyber text-lg text-white mb-4 flex items-center gap-3">
          <span class="w-1.5 h-6 bg-amber-500 rounded-full"></span>
          Offers Received
          <span class="px-2 py-0.5 rounded-full bg-amber-500/20 text-amber-400 text-xs"><%= pendingIn.length %></span>
        </h2>
        <div class="space-y-3">
          <% pendingIn.forEach(tx => { %>
            <a href="/transactions/<%= tx._id %>"
              class="glass flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-5 rounded-2xl border border-amber-500/20 hover:border-amber-500/40 transition-all group">
              <div>
                <p class="text-white font-semibold group-hover:text-amber-400 transition-colors"><%= tx.listing.title %></p>
                <p class="text-slate-500 text-xs mt-0.5"><%= tx.buyer.name %> from <%= tx.buyer.dorm || '—' %> wants this</p>
              </div>
              <span class="px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-400 text-[10px] font-cyber uppercase tracking-widest whitespace-nowrap">
                Awaiting your response →
              </span>
            </a>
          <% }); %>
        </div>
      </section>
    <% } %>

    <!-- Offers Sent (waiting on seller) -->
    <% const pendingOut = offersSent.filter(t => t.status === 'pending'); %>
    <% if (pendingOut.length > 0) { %>
      <section class="mb-10">
        <h2 class="font-cyber text-lg text-white mb-4 flex items-center gap-3">
          <span class="w-1.5 h-6 bg-cyan-500 rounded-full"></span>
          Offers Sent
          <span class="px-2 py-0.5 rounded-full bg-cyan-500/20 text-cyan-400 text-xs"><%= pendingOut.length %></span>
        </h2>
        <div class="space-y-3">
          <% pendingOut.forEach(tx => { %>
            <a href="/transactions/<%= tx._id %>"
              class="glass flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-5 rounded-2xl border border-cyan-500/20 hover:border-cyan-500/40 transition-all group">
              <div>
                <p class="text-white font-semibold group-hover:text-cyan-400 transition-colors"><%= tx.listing.title %></p>
                <p class="text-slate-500 text-xs mt-0.5">Seller: <%= tx.seller.name %> from <%= tx.seller.dorm || '—' %></p>
              </div>
              <span class="px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/30 text-cyan-400 text-[10px] font-cyber uppercase tracking-widest whitespace-nowrap">
                Waiting on seller →
              </span>
            </a>
          <% }); %>
        </div>
      </section>
    <% } %>

    <!-- My Listings -->
    <section class="mb-10">
      <h2 class="font-cyber text-lg text-white mb-4 flex items-center gap-3">
        <span class="w-1.5 h-6 bg-slate-500 rounded-full"></span>
        My Listings
        <span class="px-2 py-0.5 rounded-full bg-slate-800 text-slate-400 text-xs"><%= myListings.length %></span>
      </h2>
      <% if (myListings.length === 0) { %>
        <div class="glass p-8 rounded-3xl border-dashed border-slate-800 text-center">
          <p class="text-slate-500 font-cyber text-xs uppercase tracking-widest mb-4">No active transmissions from this unit.</p>
          <a href="/" class="inline-block text-cyan-400 hover:text-white transition-colors text-sm font-cyber uppercase tracking-tighter underline">
            Post a Listing
          </a>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <% myListings.forEach(item => { %>
            <div class="glass p-5 rounded-2xl border border-white/5 flex flex-col gap-2">
              <div class="flex justify-between items-start">
                <span class="text-[10px] font-cyber uppercase tracking-widest px-2 py-1 rounded
                  <%= item.status === 'active' ? 'bg-cyan-500/10 text-cyan-400' :
                      item.status === 'bargaining' ? 'bg-amber-500/10 text-amber-400' :
                      item.status === 'completed' ? 'bg-green-500/10 text-green-400' :
                                                    'bg-slate-700 text-slate-400' %>">
                  <%= item.status %>
                </span>
                <span class="text-xs text-slate-500"><%= item.price %></span>
              </div>
              <p class="text-white font-semibold text-sm"><%= item.title %></p>
              <p class="text-slate-500 text-xs line-clamp-2"><%= item.description %></p>
              <p class="text-[10px] font-cyber text-slate-600 uppercase"><%= item.type === 'have' ? '📦 Have' : '🔍 Need' %> &middot; <%= item.dorm %></p>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- Transaction History -->
    <%
      const allHistory = [...offersReceived, ...offersSent]
        .filter(t => ['completed','canceled'].includes(t.status))
        .sort((a, b) => new Date(b.updatedAt) - new Date(a.updatedAt));
    %>
    <% if (allHistory.length > 0) { %>
      <section>
        <h2 class="font-cyber text-lg text-white mb-4 flex items-center gap-3">
          <span class="w-1.5 h-6 bg-green-500 rounded-full"></span>
          History
          <span class="px-2 py-0.5 rounded-full bg-slate-800 text-slate-400 text-xs"><%= allHistory.length %></span>
        </h2>
        <div class="space-y-3">
          <% allHistory.forEach(tx => { %>
            <a href="/transactions/<%= tx._id %>"
              class="glass flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-5 rounded-2xl border border-white/5 hover:border-white/10 transition-all">
              <div>
                <p class="text-slate-300 font-semibold text-sm"><%= tx.listing.title %></p>
                <p class="text-slate-600 text-xs mt-0.5">
                  <%= new Date(tx.updatedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </p>
              </div>
              <span class="px-3 py-1 rounded-full text-[10px] font-cyber uppercase tracking-widest whitespace-nowrap
                <%= tx.status === 'completed' ? 'bg-green-500/10 border border-green-500/30 text-green-400' : 'bg-slate-700 border border-slate-600 text-slate-400' %>">
                <%= tx.status %>
              </span>
            </a>
          <% }); %>
        </div>
      </section>
    <% } %>

  <% } else { %>
    <div class="text-center py-20 glass rounded-3xl">
      <p class="text-slate-400 mb-6">No identity found. Please log in again.</p>
      <a href="/login" class="px-8 py-3 rounded-xl bg-cyan-500 text-slate-950 font-bold font-cyber hover:bg-cyan-400 transition-all">
        Login
      </a>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>

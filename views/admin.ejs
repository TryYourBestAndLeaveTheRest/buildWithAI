<%- include('partials/header') %>

<div class="admin-dashboard">
  <div class="admin-container">
    <!-- Dashboard Header -->
    <div class="admin-header">
      <h1>📊 Admin Dashboard</h1>
      <p>Platform usage analytics and session insights</p>
    </div>

    <!-- Key Metrics Cards -->
    <div class="metrics-grid">
      <!-- Total Page Views -->
      <div class="metric-card">
        <div class="metric-icon">👁️</div>
        <div class="metric-content">
          <div class="metric-label">Total Page Views</div>
          <div class="metric-value"><%= metrics.pageViews.totalPageViews.toLocaleString() %></div>
          <div class="metric-subtext">Last 24h: <%= metrics.pageViews.viewsInLast24.toLocaleString() %></div>
        </div>
      </div>

      <!-- Active Sessions -->
      <div class="metric-card">
        <div class="metric-icon">🔄</div>
        <div class="metric-content">
          <div class="metric-label">Total Sessions</div>
          <div class="metric-value"><%= metrics.sessions.totalSessions.toLocaleString() %></div>
          <div class="metric-subtext">Active: <%= metrics.sessions.activeSessions %></div>
        </div>
      </div>

      <!-- Avg Session Duration -->
      <div class="metric-card">
        <div class="metric-icon">⏱️</div>
        <div class="metric-content">
          <div class="metric-label">Avg Session Duration</div>
          <div class="metric-value"><%= (metrics.sessions.avgSessionDuration / 1000 / 60).toFixed(2) %> min</div>
          <div class="metric-subtext">Avg pages/session: <%= metrics.sessions.avgPageViews.toFixed(1) %></div>
        </div>
      </div>

    </div>

    <!-- Top Pages Section -->
    <div class="analytics-section">
      <div class="section-header">
        <h2>📄 Top Pages</h2>
      </div>

      <div class="analytics-card full-width">
        <div class="chart-container">
          <% if (metrics.pageViews.pageViewsByUrl && metrics.pageViews.pageViewsByUrl.length > 0) { %>
            <table class="data-table">
              <thead>
                <tr>
                  <th>Page URL</th>
                  <th>Views</th>
                  <th>Percentage</th>
                </tr>
              </thead>
              <tbody>
                <% metrics.pageViews.pageViewsByUrl.forEach(item => { %>
                  <tr>
                    <td><code><%= item._id %></code></td>
                    <td><strong><%= item.count %></strong></td>
                    <td>
                      <div class="progress-bar">
                        <div class="progress-fill" data-width="<%= (metrics.pageViews.totalPageViews > 0 ? (item.count / metrics.pageViews.totalPageViews * 100) : 0).toFixed(2) %>"></div>
                      </div>
                      <%= ((item.count / metrics.pageViews.totalPageViews) * 100).toFixed(1) %>%
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } else { %>
            <p class="empty-state">No page view data yet</p>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Recent Sessions Section -->
    <div class="analytics-section">
      <div class="section-header">
        <h2>🔄 Recent Sessions</h2>
      </div>

      <div class="analytics-card full-width">
        <div class="chart-container">
          <% if (metrics.sessions.recentSessions && metrics.sessions.recentSessions.length > 0) { %>
            <table class="data-table">
              <thead>
                <tr>
                  <th>User</th>
                  <th>Start Time</th>
                  <th>Duration</th>
                  <th>Page Views</th>
                </tr>
              </thead>
              <tbody>
                <% metrics.sessions.recentSessions.forEach(session => { %>
                  <tr>
                    <td>
                      <% if (session.userId) { %>
                        <span class="user-name"><%= session.userId.name || 'Anonymous' %></span>
                      <% } else { %>
                        <span class="user-name">Guest</span>
                      <% } %>
                    </td>
                    <td><%= new Date(session.startTime).toLocaleString() %></td>
                    <td>
                      <% 
                        let durationText = 'In Progress';
                        if (session.duration) {
                          const mins = Math.floor(session.duration / 1000 / 60);
                          const secs = Math.floor((session.duration / 1000) % 60);
                          durationText = mins > 0 ? `${mins}m ${secs}s` : `${secs}s`;
                        }
                      %>
                      <%= durationText %>
                    </td>
                    <td><%= session.pageViews %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } else { %>
            <p class="empty-state">No session data yet</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .admin-dashboard {
    padding: 40px 20px;
    background: linear-gradient(135deg, #f8f9fa 0%, #f0f2f5 100%);
    min-height: 100vh;
  }

  .admin-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .admin-header {
    margin-bottom: 40px;
    text-align: center;
  }

  .admin-header h1 {
    font-size: 32px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 8px 0;
  }

  .admin-header p {
    font-size: 16px;
    color: #666;
    margin: 0;
  }

  /* Metrics Grid */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }

  .metric-card {
    background: white;
    border-radius: 12px;
    padding: 24px;
    display: flex;
    gap: 16px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    border: 1px solid #f0f0f0;
    transition: all 0.3s ease;
  }

  .metric-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    transform: translateY(-2px);
  }

  .metric-icon {
    font-size: 40px;
    flex-shrink: 0;
  }

  .metric-content {
    flex: 1;
  }

  .metric-label {
    font-size: 12px;
    color: #999;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }

  .metric-value {
    font-size: 28px;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 4px;
  }

  .metric-subtext {
    font-size: 13px;
    color: #666;
  }

  /* Analytics Sections */
  .analytics-section {
    margin-bottom: 40px;
  }

  .section-header {
    margin-bottom: 24px;
  }

  .section-header h2 {
    font-size: 20px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
  }

  .analytics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }

  .analytics-card {
    background: white;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    border: 1px solid #f0f0f0;
  }

  .analytics-card.full-width {
    grid-column: 1 / -1;
  }

  .analytics-card h3 {
    font-size: 16px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 20px 0;
  }

  .chart-container {
    min-height: 200px;
  }

  /* Data Table */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .data-table thead {
    background-color: #f5f5f5;
    border-bottom: 2px solid #e0e0e0;
  }

  .data-table th {
    padding: 12px 16px;
    text-align: left;
    font-weight: 600;
    color: #666;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 0.5px;
  }

  .data-table td {
    padding: 14px 16px;
    border-bottom: 1px solid #f0f0f0;
    color: #333;
  }

  .data-table tr:hover {
    background-color: #fafafa;
  }

  .data-table code {
    background-color: #f5f5f5;
    padding: 4px 8px;
    border-radius: 4px;
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 12px;
  }

  /* Progress Bar */
  .progress-bar {
    height: 8px;
    background-color: #e0e0e0;
    border-radius: 4px;
    overflow: hidden;
    margin: 8px 0;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #007bff 0%, #0056b3 100%);
    border-radius: 4px;
    transition: width 0.3s ease;
  }

  /* Action Summary */
  .action-summary {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .action-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
  }

  .action-label {
    font-weight: 600;
    color: #333;
    font-size: 14px;
  }

  .action-count {
    font-size: 20px;
    font-weight: 700;
    color: #007bff;
  }

  /* User Name */
  .user-name {
    font-weight: 600;
    color: #1a1a1a;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    color: #999;
    padding: 40px 20px;
    font-size: 14px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .admin-dashboard {
      padding: 20px 16px;
    }

    .admin-header h1 {
      font-size: 24px;
    }

    .metrics-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .analytics-grid {
      grid-template-columns: 1fr;
    }

    .data-table {
      font-size: 12px;
    }

    .data-table th,
    .data-table td {
      padding: 10px 12px;
    }

    .metric-value {
      font-size: 24px;
    }
  }
</style>

<script src="/js/admin-dashboard.js"></script>

<%- include('partials/footer') %>

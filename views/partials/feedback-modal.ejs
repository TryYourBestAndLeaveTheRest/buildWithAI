      <h2>Share Your Feedback</h2>
      <p>Would you like to share feedback to help us improve this app?</p>
    </div>
    <div class="feedback-modal-buttons">
      <button id="feedbackYesBtn" class="feedback-btn feedback-btn-primary">
        Give Feedback
      </button>
      <button id="feedbackNoBtn" class="feedback-btn feedback-btn-secondary">
        No, Thanks
      </button>
    </div>
  </div>

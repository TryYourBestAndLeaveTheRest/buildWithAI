<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Campus Swap & Drop | <%= title %></title>
    <meta name="description" content="Campus Swap & Drop — a peer-to-peer micro-marketplace for campus items. Post what you have, find what you need.">
    <link rel="stylesheet" href="/css/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Orbitron:wght@400;700&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-950 text-slate-200 min-h-screen flex flex-col">

    <!-- Mobile menu overlay -->
    <div id="menu-overlay" class="fixed inset-0 bg-slate-950/80 backdrop-blur-sm z-40 overlay-hidden transition-opacity duration-300"></div>

    <!-- Mobile slide-in drawer -->
    <div id="mobile-menu" class="fixed top-0 right-0 h-full w-80 z-50 glass border-l border-white/10 p-6 flex flex-col gap-4 drawer-closed transition-transform duration-300 ease-in-out">
        <div class="flex items-center justify-between mb-6">
            <span class="font-cyber text-cyan-400 text-xs tracking-[0.2em] uppercase font-bold">Navigation</span>
            <button id="close-menu" class="w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 text-slate-400 hover:text-white hover:border-cyan-500/40 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <% if (currentUser) { %>
            <div class="px-4 py-4 rounded-2xl bg-cyan-500/10 border border-cyan-500/20 flex items-center gap-3 mb-4">
                <div class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></div>
                <div class="flex flex-col min-w-0">
                    <span class="text-[10px] font-cyber text-cyan-500/50 uppercase tracking-widest">Active Session</span>
                    <span class="text-cyan-300 font-bold text-sm truncate"><%= currentUser.name %></span>
                </div>
            </div>
        <% } %>

        <div class="flex flex-col gap-2">
            <% (navItems || []).forEach(item => { %>
                <% const isActive = currentPath === item.href; %>
                <a href="<%= item.href %>" class="px-5 py-4 rounded-2xl border text-sm font-semibold transition-all flex items-center justify-between group
                    <%= isActive ? 'bg-cyan-500/10 border-cyan-500/40 text-cyan-400' : 'border-white/5 text-slate-400 hover:text-cyan-300 hover:bg-white/5' %>">
                    <%= item.label %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </a>
            <% }); %>

            <% if (isAuthenticated) { %>
                <a href="/notifications" class="px-5 py-4 rounded-2xl border border-white/5 text-slate-400 text-sm font-semibold hover:text-cyan-300 hover:bg-white/5 transition-all flex items-center gap-2">
                    Notifications
                    <% if (unreadCount > 0) { %>
                        <span class="ml-auto px-2 py-0.5 rounded-full bg-cyan-500 text-slate-950 text-[10px] font-bold font-cyber"><%= unreadCount %></span>
                    <% } %>
                </a>
                <% if (isAdmin) { %>
                    <a href="/admin" class="px-5 py-4 rounded-2xl border border-cyan-500/30 text-cyan-300 text-sm font-semibold hover:bg-cyan-500/10 transition-all flex items-center gap-2">
                        Admin Dashboard
                    </a>
                <% } %>
            <% } %>
        </div>

        <div class="mt-auto border-t border-white/5 pt-6 flex flex-col gap-3">
            <% (authActions || []).forEach(action => { %>
                <% const isDanger = action.variant === 'danger'; %>
                <a href="<%= action.href %>" class="px-5 py-4 rounded-2xl border text-sm font-bold text-center transition-all uppercase tracking-tighter
                    <%= isDanger ? 'border-red-500/40 text-red-400 hover:bg-red-500/10 shadow-lg shadow-red-500/10' : 'bg-cyan-500 text-slate-950 hover:bg-cyan-400 shadow-lg shadow-cyan-500/20' %>">
                    <%= action.label %>
                </a>
            <% }); %>
        </div>
    </div>

    <!-- Header -->
    <header class="border-b border-white/5 glass sticky top-0 z-30">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 h-20 flex justify-between items-center">
            <!-- Logo -->
            <a href="/" class="flex items-center space-x-3 flex-shrink-0 group">
                <div class="w-10 h-10 bg-cyan-500 rounded-xl flex items-center justify-center glow-cyan group-hover:scale-110 transition-transform duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-950" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M4 2a2 2 0 00-2 2v11a3 3 0 106 0V4a2 2 0 00-2-2H4zm1 14a1 1 0 100-2 1 1 0 000 2zm5-1.757l4.9-4.9a2 2 0 000-2.828l-1.414-1.414a2 2 0 00-2.828 0L10 8.086V14.243z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="flex flex-col leading-none">
                    <span class="font-cyber text-lg font-bold tracking-tighter text-cyan-400 glow-text-cyan">CAMPUS<span class="text-white">SWAP</span></span>
                    <span class="text-[8px] font-cyber text-slate-500 uppercase tracking-[0.3em]">Micro-Market</span>
                </div>
            </a>

            <!-- Desktop nav -->
            <div class="hidden lg:flex items-center space-x-2">
                <div class="flex items-center bg-white/5 rounded-full p-1 border border-white/5 mr-4">
                    <% (navItems || []).forEach(item => { %>
                        <% const isActive = currentPath === item.href; %>
                        <a href="<%= item.href %>"
                            class="px-5 py-2 rounded-full text-xs font-bold transition-all duration-200 uppercase tracking-wider
                            <%= isActive ? 'bg-cyan-500 text-slate-950 shadow-md' : 'text-slate-400 hover:text-white' %>">
                            <%= item.label %>
                        </a>
                    <% }); %>
                </div>

                <div class="flex items-center space-x-3 border-l border-white/10 pl-4">
                    <!-- Notification bell (desktop) -->
                    <% if (isAuthenticated) { %>
                        <a href="/notifications" class="relative w-10 h-10 flex items-center justify-center rounded-xl border border-white/10 text-slate-400 hover:text-cyan-400 hover:border-cyan-500/40 transition-all group">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:animate-swing" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                            </svg>
                            <% if (unreadCount > 0) { %>
                                <span class="absolute -top-1 -right-1 w-5 h-5 rounded-full bg-cyan-500 text-slate-950 text-[10px] font-bold font-cyber flex items-center justify-center border-2 border-slate-950"><%= unreadCount > 9 ? '9+' : unreadCount %></span>
                            <% } %>
                        </a>
                        <% if (isAdmin) { %>
                            <a href="/admin" class="w-10 h-10 flex items-center justify-center rounded-xl border border-cyan-500/30 text-cyan-300 hover:text-cyan-200 hover:border-cyan-500/60 transition-all text-[10px] font-cyber tracking-wide" title="Admin Dashboard">
                                ADMIN
                            </a>
                        <% } %>
                    <% } %>

                    <!-- Username chip -->
                    <% if (currentUser && currentUser.name) { %>
                        <a href="/dashboard"
                            class="inline-flex items-center gap-3 px-4 py-2 rounded-xl border border-cyan-500/30 bg-cyan-500/5 text-cyan-300 hover:text-white hover:bg-cyan-500/10 transition-all text-xs font-bold uppercase tracking-wider">
                            <div class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse"></div>
                            <span class="max-w-[8rem] truncate"><%= currentUser.name %></span>
                        </a>
                    <% } %>

                    <% (authActions || []).forEach(action => { %>
                        <% const isDanger = action.variant === 'danger'; %>
                        <a href="<%= action.href %>"
                            class="px-5 py-2.5 rounded-xl border text-xs font-bold transition-all uppercase tracking-wider
                            <%= isDanger ? 'border-red-500/40 text-red-400 hover:bg-red-500/10' : 'bg-cyan-500 text-slate-950 hover:bg-cyan-400 shadow-lg shadow-cyan-500/10' %>">
                            <%= action.label %>
                        </a>
                    <% }); %>
                </div>
            </div>

            <!-- Mobile: hamburger button -->
            <button id="open-menu"
                class="lg:hidden flex items-center justify-center w-12 h-12 rounded-2xl bg-white/5 border border-white/10 text-slate-400 hover:text-cyan-400 hover:border-cyan-500/40 transition-all relative">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
                <% if (unreadCount > 0) { %>
                    <span class="absolute -top-1 -right-1 w-5 h-5 rounded-full bg-cyan-500 text-slate-950 text-[10px] font-bold font-cyber flex items-center justify-center border-2 border-slate-950"><%= unreadCount > 9 ? '9+' : unreadCount %></span>
                <% } %>
            </button>
        </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

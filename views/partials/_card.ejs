<div class="glass p-6 rounded-2xl border border-white/5 hover:border-cyan-500/30 transition-all group">
    <div class="flex justify-between items-start mb-4">
        <span class="px-2 py-1 rounded text-[10px] font-cyber uppercase tracking-wider <%= item.status === 'bargaining' ? 'bg-amber-500/10 text-amber-400' : 'bg-cyan-500/10 text-cyan-400' %>">
            <%= item.status === 'bargaining' ? 'Bargaining' : (item.type === 'have' ? 'Available' : 'Requested') %>
        </span>
        <span class="text-xs text-slate-500 font-medium"><%= item.price %></span>
    </div>
    <h3 class="text-lg font-bold text-white group-hover:text-cyan-400 transition-colors mb-2"><%= item.title %></h3>
    <p class="text-slate-400 text-sm mb-4 line-clamp-2"><%= item.description %></p>

    <% if (item.status === 'bargaining' && item.activeBargainer && item.activeBargainer.name) { %>
        <p class="text-[11px] text-amber-400 mb-4 font-cyber uppercase tracking-wider">
            <%= item.activeBargainer.name %> is bargaining...
        </p>
    <% } %>

    <div class="flex items-center justify-between border-t border-white/5 pt-4">
        <div class="flex items-center space-x-2">
            <div class="w-6 h-6 rounded-full bg-slate-800 flex items-center justify-center text-[10px] text-cyan-400 border border-cyan-500/20">
                <%= item.user && item.user.name ? item.user.name[0] : '?' %>
            </div>
            <div class="text-xs">
                <p class="text-slate-300 font-semibold"><%= item.user && item.user.name ? item.user.name : 'Unknown User' %></p>
                <p class="text-slate-500 text-[10px]"><%= item.dorm %></p>
            </div>
        </div>
    </div>

    <% if (isAuthenticated && currentUser && item.user && String(item.user._id) !== String(currentUser.id) && item.status === 'active') { %>
        <form action="/items/<%= item._id %>/interact" method="POST" class="mt-4 space-y-3">
            <input type="text" name="comment" placeholder="Optional comment for this post" maxlength="300"
                class="w-full bg-slate-900/50 border border-slate-800 rounded-lg px-3 py-2 text-white text-xs placeholder-slate-600 focus:outline-none focus:border-cyan-500 transition-colors">

            <% if (item.type === 'have') { %>
                <input type="hidden" name="action" value="buy">
                <button type="submit" class="w-full px-4 py-2 rounded-lg bg-cyan-500 text-slate-950 font-bold font-cyber text-xs uppercase tracking-wider hover:bg-cyan-400 transition-all">
                    Buy
                </button>
            <% } else { %>
                <input type="hidden" name="action" value="provide">
                <button type="submit" class="w-full px-4 py-2 rounded-lg bg-cyan-500 text-slate-950 font-bold font-cyber text-xs uppercase tracking-wider hover:bg-cyan-400 transition-all">
                    I have this
                </button>
            <% } %>
        </form>
    <% } %>
</div>

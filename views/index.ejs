<%- include('partials/header') %>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 lg:gap-12">
        <!-- Left Sidebar: Form -->
        <aside class="md:col-span-5 lg:col-span-4 space-y-6">
            <% if (isAuthenticated) { %>
                <div class="glass p-6 rounded-[2rem] border-white/5 shadow-2xl relative overflow-hidden group">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-cyan-500/5 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-cyan-500/10 transition-colors"></div>
                    
                    <h2 class="font-cyber text-sm text-cyan-400 mb-6 flex items-center tracking-widest uppercase font-bold">
                        <span class="w-2 h-2 bg-cyan-500 rounded-full mr-3 animate-pulse"></span>
                        Drop / Request
                    </h2>

                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="mb-6 p-4 rounded-2xl bg-red-500/10 border border-red-500/20 text-red-400 text-xs font-medium flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                            </svg>
                            <%= error %>
                        </div>
                    <% } %>

                    <form action="/items/new" method="POST" class="space-y-5 relative z-10">
                        <div>
                            <label class="block text-[10px] font-cyber text-slate-500 uppercase tracking-[0.2em] mb-3 ml-1">Transmission Type</label>
                            <div class="grid grid-cols-2 gap-3 p-1.5 bg-slate-950/50 rounded-2xl border border-white/5">
                                <label class="cursor-pointer group/label">
                                    <input type="radio" name="type" value="have"
                                        <%= (typeof formData !== 'undefined' && formData && formData.type === 'need') ? '' : 'checked' %>
                                        class="peer hidden">
                                    <div class="text-center py-2.5 rounded-xl border border-transparent peer-checked:border-cyan-500/30 peer-checked:bg-cyan-500/10 peer-checked:text-cyan-400 text-slate-500 text-xs font-bold uppercase tracking-wider transition-all hover:text-slate-300">
                                        Have
                                    </div>
                                </label>
                                <label class="cursor-pointer group/label">
                                    <input type="radio" name="type" value="need"
                                        <%= (typeof formData !== 'undefined' && formData && formData.type === 'need') ? 'checked' : '' %>
                                        class="peer hidden">
                                    <div class="text-center py-2.5 rounded-xl border border-transparent peer-checked:border-cyan-500/30 peer-checked:bg-cyan-500/10 peer-checked:text-cyan-400 text-slate-500 text-xs font-bold uppercase tracking-wider transition-all hover:text-slate-300">
                                        Need
                                    </div>
                                </label>
                            </div>
                        </div>

                        <div class="space-y-4">
                            <div>
                                <label class="block text-[10px] font-cyber text-slate-500 uppercase tracking-[0.2em] mb-2 ml-1">Item Title</label>
                                <input type="text" name="title" required
                                    value="<%= (typeof formData !== 'undefined' && formData) ? formData.title || '' : '' %>"
                                    placeholder="e.g. Dyson Fan"
                                    class="w-full bg-slate-950/50 border border-white/5 rounded-2xl px-5 py-4 text-white placeholder-slate-600 focus:outline-none focus:border-cyan-500/50 focus:ring-4 focus:ring-cyan-500/5 transition-all text-sm">
                            </div>

                            <div>
                                <label class="block text-[10px] font-cyber text-slate-500 uppercase tracking-[0.2em] mb-2 ml-1">Description</label>
                                <textarea name="description" required rows="3"
                                    placeholder="Condition, specs, etc."
                                    class="w-full bg-slate-950/50 border border-white/5 rounded-2xl px-5 py-4 text-white placeholder-slate-600 focus:outline-none focus:border-cyan-500/50 focus:ring-4 focus:ring-cyan-500/5 transition-all text-sm resize-none"><%= (typeof formData !== 'undefined' && formData) ? formData.description || '' : '' %></textarea>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-[10px] font-cyber text-slate-500 uppercase tracking-[0.2em] mb-2 ml-1">Location</label>
                                    <input type="text" name="dorm" required
                                        value="<%= (typeof formData !== 'undefined' && formData) ? formData.dorm || '' : '' %>"
                                        placeholder="Matrix Hall"
                                        class="w-full bg-slate-950/50 border border-white/5 rounded-2xl px-5 py-4 text-white text-xs placeholder-slate-600 focus:outline-none focus:border-cyan-500/50 transition-all">
                                </div>

                                <div>
                                    <label class="block text-[10px] font-cyber text-slate-500 uppercase tracking-[0.2em] mb-2 ml-1">Value</label>
                                    <input type="text" name="price" required
                                        value="<%= (typeof formData !== 'undefined' && formData) ? formData.price || '' : '' %>"
                                        placeholder="Free / $10"
                                        class="w-full bg-slate-950/50 border border-white/5 rounded-2xl px-5 py-4 text-white text-xs placeholder-slate-600 focus:outline-none focus:border-cyan-500/50 transition-all">
                                </div>
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full py-5 rounded-[1.25rem] bg-cyan-500 text-slate-950 font-bold font-cyber hover:bg-cyan-400 transition-all shadow-xl shadow-cyan-500/20 uppercase tracking-widest text-xs mt-2">
                            Broadcast Signal
                        </button>
                    </form>
                </div>
            <% } else { %>
                <div class="glass p-8 rounded-[2rem] border-white/5 bg-slate-900/40 shadow-2xl text-center relative overflow-hidden group">
                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
                    <h2 class="font-cyber text-sm text-cyan-400 mb-4 tracking-widest uppercase font-bold">Encrypted Channel</h2>
                    <p class="text-slate-400 text-xs leading-relaxed mb-8 px-4">Broadcast permissions are restricted to verified campus residents. Access the terminal to post.</p>
                    <a href="/login" class="inline-flex items-center justify-center w-full py-4 rounded-2xl bg-white/5 border border-white/10 text-cyan-400 font-bold font-cyber hover:bg-cyan-500 hover:text-slate-950 transition-all shadow-lg uppercase tracking-widest text-xs">
                        Login to Post
                    </a>
                </div>
            <% } %>
        </aside>

        <!-- Right Content: Feed -->
        <section class="md:col-span-7 lg:col-span-8">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 mb-10 border-b border-white/5 pb-8">
                <div class="flex items-center gap-4">
                    <div class="w-1 h-8 bg-cyan-500 rounded-full"></div>
                    <h1 class="font-cyber text-2xl font-bold text-white tracking-tight uppercase">Terminal Feed</h1>
                </div>
                <div class="flex p-1.5 bg-slate-950/50 space-x-2 rounded-2xl border border-white/5">
                    <button id="have-btn"
                        class="px-6 py-2.5 rounded-xl text-[10px] font-cyber font-bold border border-cyan-500/30 bg-cyan-500/10 text-cyan-400 transition-all uppercase tracking-widest">Available</button>
                    <button id="need-btn"
                        class="px-6 py-2.5 rounded-xl text-[10px] font-cyber font-bold border border-transparent text-slate-500 hover:text-slate-300 transition-all uppercase tracking-widest">Requests</button>
                </div>
            </div>

            <!-- Have (available) listings -->
            <div id="have-list" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% if (listings.length > 0) { %>
                    <% listings.forEach(item => { %>
                        <%- include('partials/_card', { item: item }) %>
                    <% }); %>
                <% } else { %>
                    <div class="col-span-full py-20 text-center glass rounded-3xl border-dashed border-slate-800">
                        <p class="text-slate-500 font-cyber">NO ITEMS BROADCASTED</p>
                    </div>
                <% } %>
            </div>

            <!-- Have pagination -->
            <% if (havePagination && havePagination.totalPages > 1) { %>
                <div class="flex justify-center items-center gap-3 mt-8" id="have-pagination">
                    <% if (havePagination.page > 1) { %>
                        <a href="?page=<%= havePagination.page - 1 %>" class="px-4 py-2 rounded-xl border border-slate-700 text-slate-400 hover:border-cyan-500/40 hover:text-cyan-300 font-cyber text-xs uppercase transition-all">← Prev</a>
                    <% } %>
                    <span class="text-slate-500 text-xs font-cyber uppercase tracking-widest">
                        Page <%= havePagination.page %> / <%= havePagination.totalPages %>
                    </span>
                    <% if (havePagination.page < havePagination.totalPages) { %>
                        <a href="?page=<%= havePagination.page + 1 %>" class="px-4 py-2 rounded-xl border border-slate-700 text-slate-400 hover:border-cyan-500/40 hover:text-cyan-300 font-cyber text-xs uppercase transition-all">Next →</a>
                    <% } %>
                </div>
            <% } %>

            <!-- Need (request) listings -->
            <div id="need-list" class="hidden grid grid-cols-1 md:grid-cols-2 gap-6">
                <% if (requests.length > 0) { %>
                    <% requests.forEach(item => { %>
                        <%- include('partials/_card', { item: item }) %>
                    <% }); %>
                <% } else { %>
                    <div class="col-span-full py-20 text-center glass rounded-3xl border-dashed border-slate-800">
                        <p class="text-slate-500 font-cyber">NO ACTIVE REQUESTS</p>
                    </div>
                <% } %>
            </div>

            <!-- Need pagination -->
            <% if (needPagination && needPagination.totalPages > 1) { %>
                <div class="hidden justify-center items-center gap-3 mt-8" id="need-pagination">
                    <% if (needPagination.page > 1) { %>
                        <a href="?page=<%= needPagination.page - 1 %>" class="px-4 py-2 rounded-xl border border-slate-700 text-slate-400 hover:border-cyan-500/40 hover:text-cyan-300 font-cyber text-xs uppercase transition-all">← Prev</a>
                    <% } %>
                    <span class="text-slate-500 text-xs font-cyber uppercase tracking-widest">
                        Page <%= needPagination.page %> / <%= needPagination.totalPages %>
                    </span>
                    <% if (needPagination.page < needPagination.totalPages) { %>
                        <a href="?page=<%= needPagination.page + 1 %>" class="px-4 py-2 rounded-xl border border-slate-700 text-slate-400 hover:border-cyan-500/40 hover:text-cyan-300 font-cyber text-xs uppercase transition-all">Next →</a>
                    <% } %>
                </div>
            <% } %>
        </section>
    </div>

<%- include('partials/footer') %>
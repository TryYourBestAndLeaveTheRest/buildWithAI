{
  "name": "campus-swap-drop",
  "version": "1.0.0",
  "description": "A micro-marketplace for campus items using Express and EJS.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./public/css/styles.css",
    "watch:css": "tailwindcss -i ./src/styles/input.css -o ./public/css/styles.css --watch",
    "dev:full": "npm run watch:css & npm run dev"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "connect-mongo": "^6.0.0",
    "dotenv": "^17.4.2",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "mongoose": "^9.4.1"
  }
}
